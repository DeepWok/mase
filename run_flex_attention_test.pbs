#!/bin/bash
#PBS -l walltime=01:00:00
#PBS -l select=1:ncpus=4:mem=32gb:ngpus=1:gpu_type=L40S
#PBS -N flex_tests
#PBS -o experiments/flex_attention/results/test_output.log
#PBS -e experiments/flex_attention/results/test_error.log

# ============================================================================
# FlexAttention Test Suite (CPU + CUDA)
# ============================================================================

cd $HOME/mase
source .venv/bin/activate

mkdir -p experiments/flex_attention/results

echo "=============================================="
echo "FlexAttention Test Suite"
echo "=============================================="
echo "Job ID: ${PBS_JOBID}"
echo "Running on node: $(hostname)"
echo "Started at: $(date)"
echo "=============================================="

nvidia-smi

echo ""
echo "PyTorch / CUDA info:"
python -c "import torch; print(f'PyTorch {torch.__version__}, CUDA: {torch.cuda.is_available()}, Device: {torch.cuda.get_device_name() if torch.cuda.is_available() else \"N/A\"}')"
echo ""

echo "----------------------------------------------"
echo "Running all FlexAttention tests (CPU + CUDA)..."
echo "----------------------------------------------"

python -m pytest test/passes/module/transforms/attention/test_flex_attention.py -v

EXIT_CODE=$?

echo "=============================================="
echo "Tests completed with exit code: ${EXIT_CODE}"
echo "Finished at: $(date)"
echo "=============================================="

exit $EXIT_CODE
